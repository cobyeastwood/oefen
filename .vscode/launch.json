{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug worker invoke",
      "runtimeExecutable": "node",
      "runtimeArgs": ["${workspaceFolder}/apps/worker/invoke.cjs"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/apps/worker-lambda/**/*.js",
        "!**/node_modules/**"
      ]
    }
  ]
}
