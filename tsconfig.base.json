{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@oefen/api-core": ["./libs/api-core/src/index.ts"],
      "@oefen/database": ["./libs/database/src/index.ts"],
      "@oefen/utils": ["./libs/utils/src/index.ts"],
      "@oefen/utils/notify": ["./libs/utils/src/notify/index.ts"],
      "@oefen/garmin": ["./libs/garmin/src/index.ts"],
      "@oefen/tracker-core": ["./libs/tracker-core/src/index.ts"],
      "@oefen/tracker-sync": ["./libs/tracker-sync/src/index.ts"],
      "@oefen/summarizer": ["./libs/summarizer/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
