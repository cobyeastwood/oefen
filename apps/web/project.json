{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "tags": ["type:app", "scope:web", "bundle:api"],
  "targets": {
    "build-api": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "main": "apps/web/src/handler.ts",
        "outputPath": "apps/web/api",
        "outputFileName": "index.js",
        "tsConfig": "apps/web/tsconfig.api.json",
        "platform": "node",
        "target": "node20",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": false,
        "esbuildOptions": {
          "outExtension": { ".js": ".js" },
          "footer": { "js": "module.exports = module.exports.default;" }
        }
      }
    }
  }
}
