{
  "name": "summary",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/summary/src",
  "projectType": "application",
  "tags": ["type:app", "platform:lambda", "bundle:worker"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["database:prisma-generate"],
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/summary",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": true,
        "external": ["@prisma/client", ".prisma/client"],
        "main": "apps/summary/src/main.ts",
        "tsConfig": "apps/summary/tsconfig.app.json",
        "generatePackageJson": false,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": { ".js": ".js" }
        }
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "LAMBDA_MODULES=dist/apps/summary/node_modules && CLIENT_DIR=$(dirname \"$(node -p \"require.resolve('@prisma/client/package.json')\")\") && ENGINE_DIR=$(dirname \"$(dirname \"$CLIENT_DIR\")\")/.prisma/client && mkdir -p \"$LAMBDA_MODULES/@prisma/client\" \"$LAMBDA_MODULES/.prisma/client\" && cp -RL \"$CLIENT_DIR/.\" \"$LAMBDA_MODULES/@prisma/client/\" && cp -RL \"$ENGINE_DIR/.\" \"$LAMBDA_MODULES/.prisma/client/\"",
        "cwd": "."
      }
    },
    "invoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["package"],
      "options": {
        "command": "node apps/summary/invoke.cjs",
        "cwd": "."
      }
    },
    "sync-ssm": {
      "executor": "nx:run-commands",
      "options": {
        "envFile": ".env",
        "env": {
          "SSM_PREFIX": "/oefen/summarizer",
          "AWS_REGION": "us-west-1"
        },
        "commands": [
          "aws ssm put-parameter --region $AWS_REGION --name $SSM_PREFIX/database-url --value \"$DATABASE_URL\" --type SecureString --overwrite",
          "aws ssm put-parameter --region $AWS_REGION --name $SSM_PREFIX/google-generative-ai-api-key --value \"$GOOGLE_GENERATIVE_AI_API_KEY\" --type SecureString --overwrite",
          "aws ssm put-parameter --region $AWS_REGION --name $SSM_PREFIX/twilio-account-sid --value \"$TWILIO_ACCOUNT_SID\" --type SecureString --overwrite",
          "aws ssm put-parameter --region $AWS_REGION --name $SSM_PREFIX/twilio-auth-token --value \"$TWILIO_AUTH_TOKEN\" --type SecureString --overwrite",
          "aws ssm put-parameter --region $AWS_REGION --name $SSM_PREFIX/twilio-from-number --value \"$TWILIO_FROM_NUMBER\" --type SecureString --overwrite"
        ],
        "cwd": ".",
        "parallel": false
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["package"],
      "options": {
        "commands": ["sam build", "sam deploy"],
        "cwd": "apps/summary",
        "parallel": false
      }
    }
  }
}
