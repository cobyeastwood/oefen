# Copy to .env in the repo root for local development.

# Supabase — transaction pooler (runtime + Prisma CLI)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — session pooler (Prisma migrations only)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Garmin Connect
GARMIN_USERNAME="your-email@example.com"
GARMIN_PASSWORD="your-password"
GARMIN_TOKENS=""

# Optional: Gemini for checkpoint summaries (summary Lambda / local fallback)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Local api-core port (`pnpm dev:api`). Vite proxies /api → here.
API_PORT=3001

# Production: async invoke summary Lambda instead of local lib
SUMMARY_FUNCTION_NAME=""

# Twilio — your Twilio number that sends texts (not the user's phone)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
